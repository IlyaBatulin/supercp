modules = ["python-3.12", "web", "bash"]
run = "bash scripts/deploy_replit.sh"

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "user"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash scripts/deploy_replit.sh"
waitForPort = 8000

[workflows.workflow.metadata]
outputType = "webview"

[[ports]]
localPort = 8000
externalPort = 80
